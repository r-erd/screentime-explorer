{
  "productName": "Screenlog",
  "version": "1.1.0",
  "identifier": "com.screenlog.dashboard",
  "build": {
    "frontendDist": "../renderer"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Screenlog",
        "width": 900,
        "height": 620,
        "minWidth": 700,
        "minHeight": 500,
        "visible": false,
        "decorations": true,
        "resizable": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "app",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../assets/iconTemplate.png",
      "../assets/iconTemplate@2x.png"
    ],
    "macOS": {
      "infoPlist": "./Info.plist"
    }
  }
}
